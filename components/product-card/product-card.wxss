.product-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2px 12px rgba(201, 177, 255, 0.1);
  transition: transform 0.3s, box-shadow 0.3s;
}

.product-card:active {
  transform: scale(0.97);
}

.image-wrapper {
  position: relative;
  width: 100%;
  height: 280rpx;
  overflow: hidden;
}

.product-image {
  width: 100%;
  height: 100%;
}

.tag {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  padding: 4rpx 16rpx;
  background: linear-gradient(135deg, #FF8FAB, #FFB7C8);
  color: #FFFFFF;
  font-size: 20rpx;
  font-weight: 600;
  border-radius: 20rpx;
}

.discount-badge {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  padding: 4rpx 12rpx;
  background: linear-gradient(135deg, #FF6B8A, #FF4757);
  color: #FFFFFF;
  font-size: 18rpx;
  font-weight: 600;
  border-radius: 16rpx;
}

.product-info {
  padding: 16rpx 16rpx 20rpx;
}

.product-name {
  display: block;
  font-size: 26rpx;
  font-weight: 700;
  color: #4A3F5C;
  line-height: 1.4;
}

.product-english {
  display: block;
  font-size: 20rpx;
  color: #C4B8D0;
  margin-top: 4rpx;
  font-style: italic;
}

.product-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 12rpx;
}

.price-group {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.price-current {
  font-size: 28rpx;
  font-weight: 700;
  color: #FF8FAB;
}

.price-original {
  font-size: 20rpx;
  color: #C4B8D0;
  text-decoration: line-through;
}

.sales {
  font-size: 20rpx;
  color: #C4B8D0;
}

/* 小尺寸（横向滚动） */
.product-card.small .image-wrapper {
  height: 240rpx;
}

.product-card.small .product-info {
  padding: 12rpx 14rpx 16rpx;
}

.product-card.small .product-name {
  font-size: 24rpx;
}

.product-card.small .price-current {
  font-size: 26rpx;
}
