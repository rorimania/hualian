.page {
  padding: 0 24rpx;
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #FFF8F5;
}

.search-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  height: 72rpx;
  padding: 0 24rpx;
  margin: 20rpx 0;
  background: rgba(255, 255, 255, 0.75);
  border-radius: 40rpx;
  border: 1rpx solid rgba(255, 143, 171, 0.12);
}

.search-icon {
  font-size: 28rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  height: 100%;
  font-size: 26rpx;
  color: #4A3F5C;
}

.placeholder {
  color: #C4B8D0;
}

.clear-btn {
  font-size: 24rpx;
  color: #FF8FAB;
  flex-shrink: 0;
  padding: 4rpx 12rpx;
}

.content {
  flex: 1;
  display: flex;
  gap: 20rpx;
  overflow: hidden;
}

.category-sidebar {
  width: 160rpx;
  flex-shrink: 0;
  background: rgba(255, 255, 255, 0.6);
  border-radius: 24rpx;
  padding: 12rpx 0;
  height: 100%;
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  padding: 20rpx 12rpx;
  margin: 4rpx 12rpx;
  border-radius: 16rpx;
  transition: all 0.3s;
}

.category-item.active {
  background: linear-gradient(135deg, #FFF0F5, #FFE8F0);
  box-shadow: 0 2px 8px rgba(255, 143, 171, 0.15);
}

.category-item:active {
  transform: scale(0.95);
}

.category-icon {
  font-size: 32rpx;
}

.category-text {
  font-size: 22rpx;
  color: #9B8EAD;
  font-weight: 500;
}

.category-item.active .category-text {
  color: #FF8FAB;
  font-weight: 700;
}

.flower-list {
  flex: 1;
  height: 100%;
  padding-bottom: 20rpx;
}

.flower-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  padding: 8rpx 0;
}

.flower-item {
  /* card sizing handled by component */
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 26rpx;
  color: #C4B8D0;
}

.tabbar-placeholder {
  height: 140rpx;
  flex-shrink: 0;
}
