.page {
  padding-bottom: 120rpx;
  background: linear-gradient(180deg, #FFF0F5 0%, #FFF8F5 40%);
  min-height: 100vh;
}

/* 图片区域 */
.image-section {
  position: relative;
  width: 100%;
}

.image-swiper {
  height: 600rpx;
}

.detail-image {
  width: 100%;
  height: 100%;
}

.image-counter {
  position: absolute;
  bottom: 24rpx;
  right: 24rpx;
  padding: 6rpx 18rpx;
  background: rgba(0, 0, 0, 0.3);
  color: #FFFFFF;
  font-size: 22rpx;
  border-radius: 20rpx;
}

.image-tag {
  position: absolute;
  top: 24rpx;
  left: 24rpx;
  padding: 8rpx 24rpx;
  background: linear-gradient(135deg, #FF8FAB, #FFB7C8);
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: 600;
  border-radius: 24rpx;
}

/* 信息区域 */
.info-section {
  padding: 28rpx 28rpx 20rpx;
}

.title-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.title-group {
  flex: 1;
}

.flower-name {
  display: block;
  font-size: 36rpx;
  font-weight: 800;
  color: #4A3F5C;
  line-height: 1.3;
}

.flower-english {
  display: block;
  font-size: 22rpx;
  color: #C4B8D0;
  font-style: italic;
  margin-top: 4rpx;
}

.favorite-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  padding: 8rpx 16rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.6);
  border: 1rpx solid rgba(201, 177, 255, 0.15);
  flex-shrink: 0;
}

.favorite-btn.active {
  background: rgba(255, 143, 171, 0.1);
  border-color: rgba(255, 143, 171, 0.2);
}

.favorite-icon {
  font-size: 32rpx;
}

.favorite-text {
  font-size: 18rpx;
  color: #9B8EAD;
}

.price-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.price-group {
  display: flex;
  align-items: baseline;
  gap: 6rpx;
}

.price-symbol {
  font-size: 24rpx;
  color: #FF8FAB;
  font-weight: 600;
}

.price-current {
  font-size: 44rpx;
  font-weight: 800;
  color: #FF8FAB;
}

.price-original {
  font-size: 24rpx;
  color: #C4B8D0;
  text-decoration: line-through;
  margin-left: 8rpx;
}

.sales-info {
  font-size: 22rpx;
  color: #C4B8D0;
}

.desc-text {
  font-size: 26rpx;
  color: #9B8EAD;
  line-height: 1.5;
}

/* 花物语 */
.story-section {
  margin: 0 28rpx 24rpx;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
}

.story-header {
  margin-bottom: 12rpx;
}

.story-title {
  font-size: 26rpx;
  font-weight: 700;
  color: #4A3F5C;
}

.story-text {
  display: block;
  font-size: 24rpx;
  color: #9B8EAD;
  line-height: 1.7;
}

/* 数量选择 */
.qty-section {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 28rpx;
}

.qty-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #4A3F5C;
}

.qty-control {
  display: flex;
  align-items: center;
  gap: 0;
  background: rgba(255, 255, 255, 0.6);
  border-radius: 30rpx;
  border: 1rpx solid rgba(201, 177, 255, 0.15);
  overflow: hidden;
}

.qty-btn {
  width: 66rpx;
  height: 66rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #4A3F5C;
  font-weight: 600;
  transition: all 0.2s;
}

.qty-btn:active {
  background: rgba(255, 143, 171, 0.1);
}

.qty-btn.disabled {
  color: #C4B8D0;
  opacity: 0.4;
}

.qty-value {
  width: 72rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 700;
  color: #4A3F5C;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 16rpx;
  padding: 16rpx 28rpx;
  padding-bottom: calc(16rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.92);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-top: 1rpx solid rgba(201, 177, 255, 0.12);
  z-index: 100;
}

.bottom-cart {
  flex: 1;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #F0E8F5, #F5F0FA);
  border-radius: 40rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #4A3F5C;
}

.cart-icon {
  font-size: 30rpx;
}

.cart-badge {
  position: absolute;
  top: 8rpx;
  left: calc(50% - 40rpx);
  min-width: 28rpx;
  height: 28rpx;
  background: #FF8FAB;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16rpx;
  color: #fff;
  font-weight: 600;
}

.cart-label {
  font-size: 26rpx;
}

.bottom-buy {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 80rpx;
  background: linear-gradient(135deg, #FF8FAB, #FFB7C8);
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #FFFFFF;
  box-shadow: 0 4px 12px rgba(255, 143, 171, 0.3);
}

.bottom-buy:active {
  opacity: 0.85;
  transform: scale(0.98);
}

/* Toast */
.toast-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
  pointer-events: none;
}

.toast-box {
  padding: 24rpx 48rpx;
  background: rgba(74, 63, 92, 0.85);
  backdrop-filter: blur(10px);
  border-radius: 40rpx;
}

.toast-text {
  font-size: 28rpx;
  color: #FFFFFF;
  font-weight: 500;
}

.bottom-placeholder {
  height: 120rpx;
}
