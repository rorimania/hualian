/* ===== 🌸 首页 ===== */

.page {
  padding: 0 24rpx 30rpx;
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF0F5 0%, #FFF8F5 30%, #FFFFFF 100%);
}

/* 搜索栏 */
.search-section {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx 0;
}

.search-bar {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 12rpx;
  height: 72rpx;
  padding: 0 28rpx;
  background: rgba(255, 255, 255, 0.75);
  border-radius: 40rpx;
  border: 1rpx solid rgba(255, 143, 171, 0.15);
  box-shadow: 0 2px 12px rgba(201, 177, 255, 0.08);
}

.search-icon {
  font-size: 28rpx;
}

.search-input {
  flex: 1;
  height: 100%;
  font-size: 26rpx;
  color: #4A3F5C;
}

.search-placeholder {
  font-size: 26rpx;
  color: #C4B8D0;
}

.header-icons {
  display: flex;
  gap: 12rpx;
}

.icon-btn {
  position: relative;
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.75);
  border-radius: 50%;
  border: 1rpx solid rgba(255, 143, 171, 0.15);
}

.icon-btn .icon-emoji {
  font-size: 32rpx;
}

.dot-badge {
  position: absolute;
  top: 4rpx;
  right: 4rpx;
  min-width: 28rpx;
  height: 28rpx;
  background: linear-gradient(135deg, #FF6B8A, #FF8FAB);
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 4rpx;
  font-size: 16rpx;
  color: #fff;
  font-weight: 600;
}

/* Banner 区域 */
.banner-section {
  margin-bottom: 24rpx;
}

/* 分类入口 */
.category-section {
  margin-bottom: 24rpx;
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
}

.category-grid {
  display: flex;
  justify-content: space-around;
  padding: 16rpx 0 8rpx;
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx;
  min-width: 100rpx;
}

.category-icon-wrapper {
  width: 88rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #FFF0F5, #FFF5FA);
  border-radius: 22rpx;
  transition: transform 0.3s;
}

.category-item:active .category-icon-wrapper {
  transform: scale(0.92);
}

.category-icon {
  font-size: 40rpx;
}

.category-name {
  font-size: 22rpx;
  color: #9B8EAD;
  font-weight: 500;
}

/* 通用 Section */
.section {
  margin-bottom: 28rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 8rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #4A3F5C;
}

.section-more {
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: 24rpx;
  color: #C4B8D0;
}

.arrow {
  font-size: 30rpx;
  line-height: 1;
}

/* 横向滚动商品列表 */
.flower-scroll {
  white-space: nowrap;
  padding: 8rpx 0 16rpx;
}

.flower-scroll-inner {
  display: flex;
  gap: 20rpx;
  padding: 0 4rpx;
}

.flower-scroll-item {
  display: inline-block;
  width: 260rpx;
  flex-shrink: 0;
}

/* 网格商品列表 */
.flower-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  padding: 8rpx 0;
}

/* 底部装饰 */
.footer-decoration {
  text-align: center;
  padding: 48rpx 0 20rpx;
}

.footer-text {
  display: block;
  font-size: 26rpx;
  color: #FF8FAB;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.footer-sub {
  display: block;
  font-size: 20rpx;
  color: #C4B8D0;
}

