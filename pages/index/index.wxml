<view class="page">

  <!-- ===== 搜索栏 ===== -->
  <view class="search-section">
    <view class="search-bar glass">
      <text class="search-icon">🔍</text>
      <input
        class="search-input"
        placeholder="搜索花束・花言葉..."
        placeholder-class="search-placeholder"
        value="{{searchValue}}"
        bindinput="onSearchInput"
        bindconfirm="onSearch"
        confirm-type="search"
      ></input>
    </view>
    <view class="header-icons">
      <view class="icon-btn" bindtap="goToCart">
        <text class="icon-emoji">🛍️</text>
        <view wx:if="{{cartCount > 0}}" class="dot-badge">{{cartCount}}</view>
      </view>
    </view>
  </view>

  <!-- ===== Banner 轮播 ===== -->
  <view class="banner-section">
    <banner banners="{{banners}}"></banner>
  </view>

  <!-- ===== 分类快捷入口 ===== -->
  <view class="category-section card">
    <view class="section-header">
      <text class="section-title">✨ 分类</text>
      <view class="section-more" bindtap="goToCategory">
        <text>查看全部</text>
        <text class="arrow">›</text>
      </view>
    </view>
    <view class="category-grid">
      <view
        class="category-item"
        wx:for="{{categories}}"
        wx:key="id"
        data-id="{{item.id}}"
        bindtap="goToDetail"
      >
        <view class="category-icon-wrapper">
          <text class="category-icon">{{item.icon}}</text>
        </view>
        <text class="category-name">{{item.name}}</text>
      </view>
    </view>
  </view>

  <!-- ===== 热销推荐 ===== -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">🔥 热销推荐</text>
      <view class="section-more" bindtap="goToCategory">
        <text>更多</text>
        <text class="arrow">›</text>
      </view>
    </view>
    <scroll-view class="flower-scroll" scroll-x>
      <view class="flower-scroll-inner">
        <view
          wx:for="{{hotFlowers}}"
          wx:key="id"
          class="flower-scroll-item"
        >
          <product-card flower="{{item}}"></product-card>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- ===== 新品上市 ===== -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">🌟 新品上市</text>
      <view class="section-more" bindtap="goToCategory">
        <text>更多</text>
        <text class="arrow">›</text>
      </view>
    </view>
    <view class="flower-grid">
      <view
        wx:for="{{newFlowers}}"
        wx:key="id"
        class="flower-grid-item"
      >
        <product-card flower="{{item}}"></product-card>
      </view>
    </view>
  </view>

  <!-- ===== 底部装饰 ===== -->
  <view class="footer-decoration">
    <text class="footer-text">🌸 花で紡ぐ、あなたの物語 🌸</text>
    <text class="footer-sub">Hanakotoba — 花言葉を添えて</text>
  </view>

</view>

