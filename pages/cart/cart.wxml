<view class="page">
  <!-- ===== 空购物车 ===== -->
  <view wx:if="{{!hasCart}}" class="empty-state">
    <text class="empty-icon">🛒</text>
    <text class="empty-title">购物车空空的</text>
    <text class="empty-desc">去挑选一束花吧 ✨</text>
    <view class="btn-primary" bindtap="goToDetail">去逛逛</view>
  </view>

  <!-- ===== 购物车列表 ===== -->
  <view wx:else class="cart-list">
    <view class="cart-header glass">
      <view class="select-all" bindtap="toggleAllSelect">
        <view class="checkbox {{allSelected ? 'checked' : ''}}">
          <text wx:if="{{allSelected}}">✓</text>
        </view>
        <text class="select-text">全选</text>
      </view>
      <text class="header-count">共 {{cart.length}} 件</text>
    </view>

    <view class="cart-items">
      <view
        wx:for="{{cart}}"
        wx:key="id"
        class="cart-item card"
      >
        <view class="checkbox-wrapper" data-id="{{item.id}}" bindtap="toggleSelect">
          <view class="checkbox {{item.selected ? 'checked' : ''}}">
            <text wx:if="{{item.selected}}">✓</text>
          </view>
        </view>
        <image class="item-image" src="{{item.image}}" mode="aspectFill"></image>
        <view class="item-info">
          <text class="item-name">{{item.name}}</text>
          <text class="item-price">¥{{item.price}}</text>
          <view class="item-qty">
            <view class="qty-btn" data-id="{{item.id}}" bindtap="decreaseQty">−</view>
            <text class="qty-value">{{item.quantity}}</text>
            <view class="qty-btn" data-id="{{item.id}}" bindtap="increaseQty">+</view>
          </view>
        </view>
        <view class="item-remove" data-id="{{item.id}}" bindtap="removeItem">
          <text>✕</text>
        </view>
      </view>
    </view>
  </view>

  <!-- ===== 底部结算栏 ===== -->
  <view wx:if="{{hasCart}}" class="bottom-bar safe-bottom">
    <view class="select-all" bindtap="toggleAllSelect">
      <view class="checkbox {{allSelected ? 'checked' : ''}}">
        <text wx:if="{{allSelected}}">✓</text>
      </view>
      <text class="select-text">全选</text>
    </view>
    <view class="total-group">
      <text class="total-label">合计：</text>
      <text class="total-price">¥{{totalPrice}}</text>
    </view>
    <view class="checkout-btn" bindtap="goToCheckout">结算</view>
  </view>

  <!-- ===== Toast ===== -->
  <view wx:if="{{showToast}}" class="toast-mask">
    <view class="toast-box">
      <text class="toast-text">{{toastText}}</text>
    </view>
  </view>

</view>
