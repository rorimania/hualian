/* ===== 🌸 花恋 - 二次元花店 全局样式 ===== */

/* 主题色 - 用类名替代 CSS 变量 */
page {
  background: #FFF8F5;
  color: #4A3F5C;
  font-family: -apple-system, 'Helvetica Neue', 'PingFang SC', sans-serif;
  font-size: 28rpx;
  line-height: 1.6;
  box-sizing: border-box;
}

/* 通用按钮 */
.btn-primary {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 48rpx;
  background: linear-gradient(135deg, #FF9EB5, #FFB7C8);
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 40rpx;
  border: none;
  box-shadow: 0 4px 12px rgba(255, 143, 171, 0.35);
}

.btn-primary:active {
  opacity: 0.8;
  transform: scale(0.97);
}

.btn-secondary {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 48rpx;
  background: linear-gradient(135deg, #C9B1FF, #E1D4FF);
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 40rpx;
  border: none;
  box-shadow: 0 4px 12px rgba(201, 177, 255, 0.35);
}

.btn-small {
  padding: 14rpx 32rpx;
  font-size: 24rpx;
}

/* 卡片样式 */
.card {
  background: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 4px 16px rgba(201, 177, 255, 0.15);
  padding: 24rpx;
}

/* 毛玻璃效果（无 backdrop-filter 确保兼容性） */
.glass {
  background: rgba(255, 255, 255, 0.75);
}

/* safe-area */
.safe-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}
